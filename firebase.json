{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/modular-phase1/**",
        "destination": "/modular-phase1/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
